class Solution {
public:
    int xorAfterQueries(vector<int>& nums, vector<vector<int>>& queries) {
        const int MOD = 1000000007;
        for (const auto& query : queries) {
            int li = query[0];
            int ri = query[1];
            int ki = query[2];
            int vi = query[3];
            for (int idx = li; idx <= ri; idx += ki) {
                nums[idx] = (static_cast<long long>(nums[idx]) * vi) % MOD;
            }
        }
        int result = 0;
        for (int num : nums) {
            result ^= num;
        }
        
        return result;
    }
};
